# =============================================================================
# AI Photo Studio WhatsApp — Project Environment Template
# =============================================================================
# Classification legend:
#   [REQUIRED]  Must be set — app will fail to boot without it
#   [OPTIONAL]  Has a safe default or is conditionally required
#   [DEPRECATED] Still accepted but slated for removal
#   [FUTURE]    Reserved for planned infrastructure migration (not yet active)
#   [LEGACY]    No longer used by the application — kept for rollback reference
#
# NO SECRETS IN THIS FILE. All values are placeholders or example IDs.
# =============================================================================

# ---- Production Domains ----
PRODUCTION_FRONTEND_DOMAIN=www.thannow.com                                                                             # [REQUIRED] Production frontend domain
PRODUCTION_API_DOMAIN=api.thannow.com                                                                                  # [REQUIRED] Production API domain
PRODUCTION_FRONTEND_URL=https://www.thannow.com                                                                        # [REQUIRED] Production frontend URL
PRODUCTION_API_URL=https://api.thannow.com                                                                             # [REQUIRED] Production API base URL

# ---- Project Identity ----
PROJECT_SIGNATURE=AI_PHOTO_STUDIO_WHATSAPP__GARDENSHOP__MAIN                                                           # [REQUIRED] Project lock verification
EXPECTED_GIT_REMOTE=https://github.com/gardenshop/ai-photo-studio-whatsapp.git                                          # [DEPRECATED] Use ai-photo-studio org
EXPECTED_GIT_BRANCH=main                                                                                               # [REQUIRED] Deployment branch lock

# ---- Railway (Legacy — Do Not Use) ----
RAILWAY_PROJECT_ID=ad62f340-fcfd-4989-b5bb-18753b28d8c8                                                               # [LEGACY] Railway no longer in use
RAILWAY_PROJECT_NAME=AI Photo Studio WhatsApp                                                                          # [LEGACY] Railway no longer in use
RAILWAY_ENVIRONMENT=production                                                                                         # [LEGACY] Railway no longer in use
RAILWAY_ENVIRONMENT_ID=13228f5e-8af5-4f5e-b57e-b1dfccd567ec                                                           # [LEGACY] Railway no longer in use
RAILWAY_SERVICE=api                                                                                                    # [LEGACY] Railway no longer in use

# ---- Cloudflare R2 (Active) ----
R2_ACCOUNT_ID=2eb5eadd4af6da3d3a5f6c61d92437e4                                                                        # [REQUIRED] Cloudflare account ID
R2_BUCKET_NAME=ai-photo-studio-storage                                                                                 # [REQUIRED] R2 bucket for image storage
R2_PUBLIC_BASE_URL=https://2eb5eadd4af6da3d3a5f6c61d92437e4.r2.cloudflarestorage.com                                  # [REQUIRED] R2 public endpoint
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID                                                                         # [REQUIRED] R2 S3-compatible access key
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY                                                                 # [REQUIRED] R2 S3-compatible secret key

# ---- Cloudflare Pages (Active — Frontend) ----
CLOUDFLARE_ACCOUNT_ID=2eb5eadd4af6da3d3a5f6c61d92437e4                                                               # [REQUIRED] Cloudflare account ID
CLOUDFLARE_PAGES_PROJECT=ai-photo-studio-frontend                                                                      # [REQUIRED] Cloudflare Pages project name
CLOUDFLARE_ZONE_ID=REPLACE_WITH_CLOUDFLARE_ZONE_ID                                                                     # [REQUIRED] Cloudflare DNS zone ID for thannow.com
CLOUDFLARE_API_TOKEN=REPLACE_WITH_CLOUDFLARE_API_TOKEN                                                                 # [FUTURE] Cloudflare API token (GH secret, not in env)

# ---- RunPod Serverless GPU (Future — AI Services) ----
# Each endpoint is a RunPod serverless endpoint ID. Set as GitHub Secrets in production.
# Endpoints are NOT deployed yet. This is the target mapping.
RUNPOD_API_KEY=REPLACE_WITH_RUNPOD_API_KEY                                                                             # [FUTURE] RunPod API key (GitHub secret)
RUNPOD_BG_REMOVER_ENDPOINT=REPLACE_WITH_BG_REMOVER_ENDPOINT_ID                                                        # [FUTURE] Background removal (u2netp / sam2)
RUNPOD_LAMA_ENDPOINT=REPLACE_WITH_LAMA_ENDPOINT_ID                                                                     # [FUTURE] LaMa inpainting
RUNPOD_GFPGAN_ENDPOINT=REPLACE_WITH_GFPGAN_ENDPOINT_ID                                                                # [FUTURE] GFPGAN face restoration
RUNPOD_CODEFORMER_ENDPOINT=REPLACE_WITH_CODEFORMER_ENDPOINT_ID                                                         # [FUTURE] CodeFormer face enhancement
RUNPOD_DDCOLOR_ENDPOINT=REPLACE_WITH_DDCOLOR_ENDPOINT_ID                                                               # [FUTURE] DDColor colorization
RUNPOD_REAL_ESRGAN_ENDPOINT=REPLACE_WITH_REAL_ESRGAN_ENDPOINT_ID                                                       # [FUTURE] Real-ESRGAN upscaling

# ---- RunPod Endpoint URLs (Constructed from endpoint IDs at runtime) ----
# The following URL patterns are used by the API to reach each service:
# https://api.runpod.ai/v2/{ENDPOINT_ID}/runsync
# These are NOT set as env vars — they are derived from the endpoint IDs above.

# ---- Neon PostgreSQL (Future — Replace Cloud SQL) ----
NEON_PROJECT_ID=REPLACE_WITH_NEON_PROJECT_ID                                                                           # [FUTURE] Neon project ID
NEON_DATABASE_URL=postgresql://user:password@neon-host/ai_photo_studio?sslmode=require&pgbouncer=true                  # [FUTURE] Neon connection string (replaces DATABASE_URL)
NEON_API_KEY=REPLACE_WITH_NEON_API_KEY                                                                                 # [FUTURE] Neon project API key
NEON_BRANCH=main                                                                                                       # [FUTURE] Neon database branch
NEON_POOLER_URL=postgresql://user:password@neon-host/ai_photo_studio?sslmode=require&pgbouncer=true&pool=transaction   # [FUTURE] Neon connection pooler URL

# ---- Upstash Redis (Future — Replace Memorystore) ----
UPSTASH_REDIS_REST_URL=https://REPLACE_WITH_UPSTASH_URL.upstash.io                                                    # [FUTURE] Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_TOKEN                                                                    # [FUTURE] Upstash Redis REST token
UPSTASH_REDIS_ENDPOINT=REPLACE_WITH_UPSTASH_URL.upstash.io                                                             # [FUTURE] Upstash Redis endpoint (for ioredis)
UPSTASH_REDIS_PORT=6379                                                                                                # [FUTURE] Upstash Redis port (TLS: 6380)

# ---- Application AI Service URLs (Production) ----
# These point to the RunPod endpoints once provisioned. For now they point to local dev.
BACKGROUND_API_URL=https://api.thannow.com/ai/bg-remover                                                               # [FUTURE] Background remover API URL
PRODUCT_CLASSIFIER_URL=https://api.thannow.com/ai/product-classifier                                                   # [FUTURE] Product classifier API URL
YOLO_DETECTOR_URL=https://api.thannow.com/ai/yolo-detector                                                             # [FUTURE] YOLO detector API URL
REAL_ESRGAN_URL=https://api.thannow.com/ai/real-esrgan                                                                 # [FUTURE] Real-ESRGAN upscaling URL
IC_LIGHT_LAB_URL=https://api.thannow.com/ai/ic-light                                                                   # [FUTURE] IC-Light service URL
RESTORATION_LAMA_URL=https://api.thannow.com/ai/lama                                                                   # [FUTURE] LaMa inpainting URL
RESTORATION_GFPGAN_URL=https://api.thannow.com/ai/gfpgan                                                               # [FUTURE] GFPGAN face restoration URL
RESTORATION_CODEFORMER_URL=https://api.thannow.com/ai/codeformer                                                       # [FUTURE] CodeFormer face enhancement URL
RESTORATION_DDCOLOR_URL=https://api.thannow.com/ai/ddcolor                                                             # [FUTURE] DDColor colorization URL

