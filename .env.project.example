# =============================================================================
# AI Photo Studio WhatsApp — Project Environment Template
# =============================================================================
# Classification legend:
#   [REQUIRED]  Must be set — app will fail to boot without it
#   [OPTIONAL]  Has a safe default or is conditionally required
#   [DEPRECATED] Still accepted but slated for removal
#   [LEGACY]    No longer used by the application — kept for rollback reference
#
# NO SECRETS IN THIS FILE. All values are placeholders or example IDs.
# =============================================================================

# ---- Production Domains ----
PRODUCTION_FRONTEND_DOMAIN=www.thannow.com                                                                             # [REQUIRED] Production frontend domain
PRODUCTION_API_DOMAIN=api.thannow.com                                                                                  # [REQUIRED] Production API domain
PRODUCTION_FRONTEND_URL=https://www.thannow.com                                                                        # [REQUIRED] Production frontend URL
PRODUCTION_API_URL=https://api.thannow.com                                                                             # [REQUIRED] Production API base URL

# ---- Project Identity ----
PROJECT_SIGNATURE=AI_PHOTO_STUDIO_WHATSAPP__GARDENSHOP__MAIN                                                           # [REQUIRED] Project lock verification
EXPECTED_GIT_REMOTE=https://github.com/ai-photo-studio/ai-photo-studio.git                                             # [REQUIRED] Git remote verification
EXPECTED_GIT_BRANCH=main                                                                                               # [REQUIRED] Deployment branch lock

# ---- Cloudflare R2 (Active) ----
R2_ACCOUNT_ID=2eb5eadd4af6da3d3a5f6c61d92437e4                                                                        # [REQUIRED] Cloudflare account ID
R2_BUCKET_NAME=ai-photo-studio-storage                                                                                 # [REQUIRED] R2 bucket for image storage
R2_PUBLIC_BASE_URL=https://2eb5eadd4af6da3d3a5f6c61d92437e4.r2.cloudflarestorage.com                                  # [REQUIRED] R2 public endpoint
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID                                                                         # [REQUIRED] R2 S3-compatible access key
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY                                                                 # [REQUIRED] R2 S3-compatible secret key

# ---- Cloudflare Pages (Active — Frontend) ----
CLOUDFLARE_ACCOUNT_ID=2eb5eadd4af6da3d3a5f6c61d92437e4                                                               # [REQUIRED] Cloudflare account ID
CLOUDFLARE_PAGES_PROJECT=ai-photo-studio-frontend                                                                      # [REQUIRED] Cloudflare Pages project name
CLOUDFLARE_ZONE_ID=REPLACE_WITH_CLOUDFLARE_ZONE_ID                                                                     # [REQUIRED] Cloudflare DNS zone ID for thannow.com

# ---- RunPod Serverless GPU (Active — AI Services) ----
RUNPOD_API_KEY=REPLACE_WITH_RUNPOD_API_KEY                                                                             # [REQUIRED] RunPod API key (GitHub secret)
RUNPOD_BG_REMOVER_ENDPOINT=REPLACE_WITH_BG_REMOVER_ENDPOINT_ID                                                        # [REQUIRED] Background removal endpoint ID
RUNPOD_S3_ACCESS_KEY=REPLACE_WITH_S3_ACCESS_KEY                                                                        # [REQUIRED] RunPod S3-compatible access key
RUNPOD_S3_SECRET_KEY=REPLACE_WITH_S3_SECRET_KEY                                                                        # [REQUIRED] RunPod S3-compatible secret key

# ---- Neon PostgreSQL (Active — Database) ----
NEON_PROJECT_ID=REPLACE_WITH_NEON_PROJECT_ID                                                                           # [REQUIRED] Neon project ID
NEON_API_KEY=REPLACE_WITH_NEON_API_KEY                                                                                 # [REQUIRED] Neon API key
NEON_DATABASE_URL=postgresql://user:password@neon-host/ai_photo_studio?sslmode=require&pgbouncer=true                  # [REQUIRED] Neon connection string (replaces DATABASE_URL)
NEON_DIRECT_URL=postgresql://user:password@neon-host/ai_photo_studio?sslmode=require                                   # [REQUIRED] Neon direct (non-pooled) connection
NEON_POOLER_URL=postgresql://user:password@neon-host/ai_photo_studio?sslmode=require&pgbouncer=true&pool=transaction   # [REQUIRED] Neon transaction pooler URL

# ---- Upstash Redis (Active — Queue & Cache) ----
UPSTASH_REDIS_REST_URL=https://REPLACE_WITH_UPSTASH_URL.upstash.io                                                    # [REQUIRED] Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_TOKEN                                                                    # [REQUIRED] Upstash Redis REST token
UPSTASH_REDIS_ENDPOINT=REPLACE_WITH_UPSTASH_URL.upstash.io                                                             # [REQUIRED] Upstash Redis endpoint (for ioredis)
UPSTASH_REDIS_PORT=6379                                                                                                # [REQUIRED] Upstash Redis port (TLS: 6380)

# ---- GitHub Secrets (must match deploy.yml) ----
JWT_SECRET=REPLACE_WITH_JWT_SECRET                                                                                     # [REQUIRED] JSON Web Token signing secret
ADMIN_JWT_SECRET=REPLACE_WITH_ADMIN_JWT_SECRET                                                                         # [REQUIRED] Admin JWT signing secret
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_WHATSAPP_VERIFY_TOKEN                                                               # [REQUIRED] WhatsApp webhook verification token
WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_WHATSAPP_ACCESS_TOKEN                                                               # [REQUIRED] WhatsApp API access token
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_WHATSAPP_PHONE_NUMBER_ID                                                         # [REQUIRED] WhatsApp Business phone number ID
PAYMENT_GATEWAY_NAME=manual                                                                                            # [REQUIRED] Payment gateway provider
PAYMENT_GATEWAY_BASE_URL=REPLACE_WITH_PAYMENT_GATEWAY_URL                                                              # [REQUIRED] Payment gateway base URL
PAYMENT_GATEWAY_SECRET=REPLACE_WITH_PAYMENT_GATEWAY_SECRET                                                             # [REQUIRED] Payment gateway secret key

# ---- Application AI Service URLs (Production) ----
# These point to RunPod endpoints via RESTORATION_ENDPOINT_URL.
BACKGROUND_API_URL=krovsimtvnr75h                                                                                    # [REQUIRED] RunPod ai-bg-remover endpoint ID
PRODUCT_CLASSIFIER_URL=http://10.0.0.1:8080                                                                            # [PLACEHOLDER] No classifier deployed yet; passes validation
PRODUCT_CLASSIFIER_URL=https://api.thannow.com/ai/product-classifier                                                   # [FUTURE] Product classifier API URL
YOLO_DETECTOR_URL=https://api.thannow.com/ai/yolo-detector                                                             # [FUTURE] YOLO detector API URL
REAL_ESRGAN_URL=https://api.thannow.com/ai/real-esrgan                                                                 # [FUTURE] Real-ESRGAN upscaling URL
IC_LIGHT_LAB_URL=https://api.thannow.com/ai/ic-light                                                                   # [FUTURE] IC-Light service URL
RESTORATION_ENDPOINT_URL=3z633s11yn4n8q                                                                                # [REQUIRED] RunPod unified-restoration endpoint ID

# ---- Deployment Environment Variables ----
ALLOWED_ORIGINS=https://www.thannow.com                                                                                # [REQUIRED] CORS allowed origins
AI_PROVIDER=local-rembg                                                                                                # [REQUIRED] AI provider name
STORAGE_PROVIDER=r2                                                                                                    # [REQUIRED] Storage provider
DELIVERY_MODE=WHATSAPP                                                                                                  # [REQUIRED] Delivery mode (WHATSAPP/LOG_ONLY)
R2_ACCOUNT_ID=2eb5eadd4af6da3d3a5f6c61d92437e4                                                                        # [REQUIRED] Cloudflare account ID
R2_BUCKET_NAME=ai-photo-studio-storage                                                                                 # [REQUIRED] R2 bucket name
R2_PUBLIC_BASE_URL=https://2eb5eadd4af6da3d3a5f6c61d92437e4.r2.cloudflarestorage.com                                  # [REQUIRED] R2 public endpoint

# ---- Job Timeout Configuration ----
QUEUE_TIMEOUT_SECONDS=60                                                                                                # [REQUIRED] Max seconds a job waits in queue before timeout
PROCESSING_TIMEOUT_SECONDS=90                                                                                           # [REQUIRED] Max seconds for GPU processing before timeout
ABSOLUTE_TIMEOUT_SECONDS=150                                                                                            # [REQUIRED] Absolute max lifetime for any job (queue+processing)

