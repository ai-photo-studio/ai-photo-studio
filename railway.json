{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev && npm run prisma:generate -w apps/api && npm run build -w apps/api"
  },
  "deploy": {
    "startCommand": "node node_modules/tsx/dist/cli.mjs apps/api/src/index.ts",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120
  }
}
