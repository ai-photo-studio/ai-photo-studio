NODE_ENV=development
PORT=4000

# Database — Local or Neon (set in production via Secret Manager)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_photo_studio

# Redis — Local or Upstash (set in production via Secret Manager)
REDIS_URL=redis://localhost:6379

# Storage — Cloudflare R2 (public values, secrets via env)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=2eb5eadd4af6da3d3a5f6c61d92437e4
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=ai-photo-studio-storage
R2_PUBLIC_BASE_URL=https://2eb5eadd4af6da3d3a5f6c61d92437e4.r2.cloudflarestorage.com

# AI Service URLs (local development)
BACKGROUND_API_URL=http://127.0.0.1:8001
PRODUCT_CLASSIFIER_URL=http://127.0.0.1:8002
YOLO_DETECTOR_URL=http://127.0.0.1:8002
REAL_ESRGAN_URL=http://127.0.0.1:8003
IC_LIGHT_LAB_URL=http://127.0.0.1:8004
RESTORATION_ENDPOINT_URL=http://127.0.0.1:8010

# WhatsApp
WHATSAPP_VERIFY_TOKEN=replace_me
WHATSAPP_ACCESS_TOKEN=replace_me
WHATSAPP_PHONE_NUMBER_ID=replace_me

# Payment
PAYMENT_GATEWAY_NAME=mock
PAYMENT_GATEWAY_BASE_URL=https://example-gateway.test
PAYMENT_GATEWAY_SECRET=replace_me

# AI Provider
AI_PROVIDER_NAME=mock
AI_PROVIDER_API_KEY=

# Authentication (secrets in production via Secret Manager)
JWT_SECRET=replace_me
ADMIN_JWT_SECRET=replace_me

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://www.thannow.com
